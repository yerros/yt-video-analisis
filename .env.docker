# ==============================================
# Video Analysis - Docker Environment Variables
# ==============================================
# Copy file ini sebagai .env untuk Docker deployment
# Isi semua variable yang REQUIRED

# ==============================================
# OpenAI Configuration (REQUIRED)
# ==============================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ==============================================
# YouTube Configuration (REQUIRED)
# ==============================================
# Get YouTube Data API v3 key from: https://console.cloud.google.com/
YOUTUBE_API_KEY=your-youtube-api-key-here

# Optional: Browser untuk extract cookies otomatis (local dev only, not for Docker)
# Leave empty for Docker deployment - cookies extraction won't work in containers
# Supported: chrome, firefox, edge, safari, opera, brave, chromium
YOUTUBE_COOKIES_BROWSER=

# Optional: Path ke cookies.txt file (recommended untuk menghindari bot detection)
# File cookies harus diletakkan di folder ./cookies/ di root project
# Export cookies dari browser: https://github.com/yt-dlp/yt-dlp/wiki/FAQ#how-do-i-pass-cookies-to-yt-dlp
# Default path (sesuai volume mount di docker-compose):
YOUTUBE_COOKIES_PATH=/app/cookies/www.youtube.com_cookies.txt

# bgutil PO Token Provider - untuk generate YouTube GVS PO Token otomatis
# Jangan diubah jika menggunakan docker-compose default
# Docs: https://github.com/Brainicism/bgutil-ytdlp-pot-provider
BGUTIL_PROVIDER_URL=http://bgutil-provider:4416

# ==============================================
# Database Configuration (REQUIRED)
# ==============================================
# PostgreSQL dengan pgvector extension
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-to-secure-password
POSTGRES_DB=video_analysis
POSTGRES_PORT=5432

# ==============================================
# Redis Configuration
# ==============================================
# Redis sebagai message broker untuk Celery
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ==============================================
# Application Settings
# ==============================================
# Temporary directory untuk video processing
TEMP_DIR=/tmp/video-analysis

# Maximum video duration dalam seconds (default: 30 minutes)
MAX_VIDEO_DURATION=1800

# Maximum frames untuk extraction
MAX_FRAMES=30

# ==============================================
# Worker Monitor Configuration
# ==============================================
# Health check interval dalam seconds
WORKER_HEALTH_CHECK_INTERVAL=60

# Health check timeout dalam seconds
WORKER_HEALTH_CHECK_TIMEOUT=10

# Maximum restart attempts sebelum cooldown
WORKER_MAX_RESTART_ATTEMPTS=3

# Cooldown period dalam seconds (5 minutes)
WORKER_RESTART_COOLDOWN=300

# ==============================================
# Frontend Configuration (REQUIRED)
# ==============================================
# Public API URL - ganti dengan IP/domain server Anda
# Format: http://your-server-ip:1945 atau https://your-domain.com
# IMPORTANT: Gunakan IP server atau domain, BUKAN localhost!
# localhost akan mengarah ke komputer client, bukan server
NEXT_PUBLIC_API_URL=http://192.168.1.45:1945

# Ports (menggunakan port unik untuk production)
BACKEND_PORT=1945
FRONTEND_PORT=1946

# ==============================================
# Storage Configuration (OPTIONAL)
# ==============================================
# Pilih salah satu: Supabase atau AWS S3
# Jika tidak diisi, akan menggunakan local filesystem

# --- Supabase Storage ---
# Get from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=video-frames

# --- AWS S3 Storage ---
# Get from: https://console.aws.amazon.com/iam/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ==============================================
# Nginx Configuration (OPTIONAL - for production)
# ==============================================
# Only needed if using nginx reverse proxy profile
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ==============================================
# Notes
# ==============================================
# 1. Minimal configuration yang REQUIRED:
#    - OPENAI_API_KEY
#    - YOUTUBE_API_KEY
#    - POSTGRES_PASSWORD
#    - NEXT_PUBLIC_API_URL
#
# 2. Untuk Portainer deployment:
#    - Set NEXT_PUBLIC_API_URL dengan IP server Anda
#    - Contoh: http://192.168.1.100:1945
#
# 3. Security:
#    - JANGAN commit file .env ke git!
#    - Gunakan password yang kuat untuk POSTGRES_PASSWORD
#    - Generate secure password: openssl rand -base64 32
#
# 4. YouTube Cookies:
#    - Sangat direkomendasikan untuk menghindari bot detection
#    - Gunakan YOUTUBE_COOKIES_BROWSER atau YOUTUBE_COOKIES_PATH
#
# 5. Storage:
#    - Local filesystem: Tidak perlu konfigurasi storage
#    - Cloud storage: Isi Supabase atau AWS credentials
#
# ==============================================
