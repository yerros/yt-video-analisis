# OpenAI
OPENAI_API_KEY=sk-...

# YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/video_analysis

# Redis
REDIS_URL=redis://localhost:6379/0

# Application
TEMP_DIR=/tmp/video-analysis
MAX_VIDEO_DURATION=1800
MAX_FRAMES=30

# YouTube Download (yt-dlp)
# Optional: Path to cookies.txt file to avoid YouTube bot detection
# Export cookies from your browser: https://github.com/yt-dlp/yt-dlp/wiki/FAQ#how-do-i-pass-cookies-to-yt-dlp
YOUTUBE_COOKIES_PATH=

# Optional: Extract cookies directly from browser (if YOUTUBE_COOKIES_PATH not set)
# Supported: chrome, firefox, edge, safari, opera, brave, chromium
YOUTUBE_COOKIES_BROWSER=chrome

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:1945

# Docker Ports (default untuk production)
BACKEND_PORT=1945
FRONTEND_PORT=1946
POSTGRES_PORT=5432
REDIS_PORT=6379
