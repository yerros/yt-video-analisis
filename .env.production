# ==============================================
# PRODUCTION ENVIRONMENT VARIABLES
# ==============================================
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env file to version control!

# ==============================================
# DATABASE CONFIGURATION
# ==============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=video_analysis
POSTGRES_PORT=5432

# ==============================================
# REDIS CONFIGURATION
# ==============================================
REDIS_PORT=6379

# ==============================================
# API KEYS (REQUIRED)
# ==============================================
# OpenAI API Key - Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# YouTube Data API v3 Key - Get from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your-youtube-api-key-here

# ==============================================
# APPLICATION CONFIGURATION
# ==============================================
# Backend port (default: 8000)
BACKEND_PORT=8000

# Frontend port (default: 3000)
FRONTEND_PORT=3000

# Frontend API URL (change to your production domain)
# Examples: 
#   - http://localhost:8000 (development)
#   - https://api.yourdomain.com (production)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Temporary directory for video processing
TEMP_DIR=/tmp/video-analysis

# Maximum video duration in seconds (default: 1800 = 30 minutes)
MAX_VIDEO_DURATION=1800

# Maximum frames to extract per video (default: 30)
MAX_FRAMES=30

# ==============================================
# YOUTUBE DOWNLOAD CONFIGURATION (OPTIONAL)
# ==============================================
# Path to YouTube cookies.txt file to avoid bot detection
# How to export cookies: https://github.com/yt-dlp/yt-dlp/wiki/FAQ#how-do-i-pass-cookies-to-yt-dlp
# Example: ./www.youtube.com_cookies.txt
YOUTUBE_COOKIES_PATH=

# Proxy Configuration (to avoid YouTube bot detection)
# Format: socks5://username:password@host:port or http://username:password@host:port
# Example: socks5://user-rotate:pass123@p.webshare.io:80
# Recommended: Use rotating proxies from Webshare.io, BrightData, or Oxylabs
# Leave empty to disable proxy
PROXY_URL=
# Alternative: Separate proxy credentials
PROXY_USERNAME=
PROXY_PASSWORD=
PROXY_HOST=
PROXY_PORT=
PROXY_TYPE=socks5

# ==============================================
# STORAGE CONFIGURATION (Choose one)
# ==============================================

# Option 1: Supabase Storage
# Get credentials from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=video-frames

# Option 2: AWS S3 Storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ==============================================
# NGINX CONFIGURATION (For production deployment)
# ==============================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ==============================================
# NOTES
# ==============================================
# 1. For development, use docker-compose up
# 2. For production with nginx, use: docker-compose --profile production up
# 3. Generate secure passwords: openssl rand -base64 32
# 4. Always use HTTPS in production
# 5. Configure firewall to allow only necessary ports
